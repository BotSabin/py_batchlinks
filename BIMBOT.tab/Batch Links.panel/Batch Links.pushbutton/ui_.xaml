<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM Link Manager v3.1"
        Height="640"
        Width="1120"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="BIM Link Manager v3.1"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,12">

            <CheckBox x:Name="chkRelativePath"
                      Content="Relative Path"
                      IsChecked="True"
                      Margin="0,0,20,0"/>

            <CheckBox x:Name="chkReplaceExisting"
                      Content="Replace Existing Links"
                      IsChecked="False"
                      Margin="0,0,20,0"/>

            <CheckBox x:Name="chkRebuildIFC"
                      Content="Rebuild IFC Cache"
                      IsChecked="False"
                      Margin="0,0,20,0"/>
        </StackPanel>

        <ListView x:Name="lvLinks"
                  Grid.Row="2"
                  Margin="0,0,0,12">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="40">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding checked, Mode=TwoWay}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Link Name"
                                    Width="560"
                                    DisplayMemberBinding="{Binding name}"/>

                    <GridViewColumn Header="Status"
                                    Width="120"
                                    DisplayMemberBinding="{Binding status}"/>

                    <GridViewColumn Header="Type"
                                    Width="90"
                                    DisplayMemberBinding="{Binding link_kind}"/>

                    <GridViewColumn Header="Type Id"
                                    Width="90"
                                    DisplayMemberBinding="{Binding typeid}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,0,0,12">

            <Button Content="Load Links"
                    Width="120"
                    Margin="0,0,8,0"
                    Click="load_links"/>

            <Button Content="Check All"
                    Width="90"
                    Margin="0,0,8,0"
                    Click="check_all"/>

            <Button Content="Uncheck All"
                    Width="100"
                    Margin="0,0,16,0"
                    Click="uncheck_all"/>

            <Button Content="Reload Selected"
                    Width="130"
                    Margin="0,0,8,0"
                    Click="reload_selected"/>

            <Button x:Name="btnUnloadForMe"
                    Content="Unload For Me"
                    Width="120"
                    Margin="0,0,8,0"
                    Click="unload_for_me"/>

            <Button Content="Unload For All"
                    Width="120"
                    Margin="0,0,8,0"
                    Click="unload_for_all"/>

            <Button Content="Cancel"
                    Width="90"
                    Click="cancel_process"/>
        </StackPanel>

        <StackPanel Grid.Row="4">
            <ProgressBar x:Name="pbProgress"
                         Height="18"
                         Minimum="0"
                         Maximum="100"
                         Value="0"
                         Margin="0,0,0,6"/>

            <TextBlock x:Name="txtStatus"
                       Text="Ready"
                       FontSize="12"/>
        </StackPanel>
    </Grid>
</Window>
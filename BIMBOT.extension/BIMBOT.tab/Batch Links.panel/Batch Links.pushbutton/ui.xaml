<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM Link Manager"
        Height="720"
        Width="1320"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#F4F6F8">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="14,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="14,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#E9EEF3"/>
            <Setter Property="Foreground" Value="#263238"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="BorderBrush" Value="#D0D7DE"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1F2933">
            <StackPanel Margin="16">
                <TextBlock Text="BIM" Foreground="White" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="Link Manager" Foreground="#B0BEC5" FontSize="13" Margin="0,0,0,28"/>

                <TextBlock Text="LINKS" Foreground="#90A4AE" FontSize="11" FontWeight="Bold" Margin="4,0,0,10"/>

                <Button Content="All Links" Click="show_all_links"/>
                <Button Content="RVT Links" Style="{StaticResource SecondaryButton}" Click="show_rvt_links"/>
                <Button Content="IFC Links" Style="{StaticResource SecondaryButton}" Click="show_ifc_links"/>
                <Button Content="CAD Links" Style="{StaticResource SecondaryButton}" Click="show_cad_links"/>
                <Button Content="Point Clouds" Style="{StaticResource SecondaryButton}" Click="show_pointcloud_links"/>
                <Button Content="NWC / NWD" Style="{StaticResource SecondaryButton}" Click="show_nwc_links"/>

                <Separator Margin="0,24,0,24"/>

                <TextBlock Text="OPTIONS" Foreground="#90A4AE" FontSize="11" FontWeight="Bold" Margin="4,0,0,8"/>

                <CheckBox x:Name="chkRelativePath" Content="Relative path" IsChecked="True" Foreground="White" Margin="4,6"/>
                <CheckBox x:Name="chkReplaceExisting" Content="Replace existing" Foreground="White" Margin="4,6"/>
                <CheckBox x:Name="chkRebuildIFC" Content="Rebuild IFC cache" Foreground="White" Margin="4,6"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,14">
                <TextBlock Text="Links" FontSize="24" FontWeight="Bold" Foreground="#263238" DockPanel.Dock="Left"/>
                <Button Content="Load Links" Width="120" HorizontalAlignment="Right" Click="load_links" DockPanel.Dock="Right"/>
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtSearch" Grid.Column="0" TextChanged="search_changed"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                    <Button Content="Check All" Style="{StaticResource SecondaryButton}" Click="check_all"/>
                    <Button Content="Uncheck All" Style="{StaticResource SecondaryButton}" Click="uncheck_all"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Background="White" BorderBrush="#D0D7DE" BorderThickness="1">
                <ListView x:Name="lvLinks" BorderThickness="0" SelectionChanged="link_selected">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="42">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding checked, Mode=TwoWay}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="Model Name" Width="320" DisplayMemberBinding="{Binding name}"/>
                            <GridViewColumn Header="Type" Width="60" DisplayMemberBinding="{Binding link_kind}"/>
                            <GridViewColumn Header="Size" Width="85" DisplayMemberBinding="{Binding size}"/>
                            <GridViewColumn Header="Status" Width="85" DisplayMemberBinding="{Binding status}"/>
                            <GridViewColumn Header="Path" Width="360" DisplayMemberBinding="{Binding path}"/>
                            <GridViewColumn Header="Id" Width="65" DisplayMemberBinding="{Binding typeid}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <Grid Grid.Row="3" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <ProgressBar x:Name="pbProgress" Height="16" Minimum="0" Maximum="100" Value="0"/>
                    <TextBlock x:Name="txtStatus" Text="Ready" Margin="0,6,0,0" Foreground="#546E7A"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                    <Button Content="Reload" Width="105" Click="reload_selected"/>
                    <Button x:Name="btnUnloadForMe" Content="Unload Me" Width="110" Style="{StaticResource SecondaryButton}" Click="unload_for_me"/>
                    <Button Content="Unload All" Width="110" Style="{StaticResource SecondaryButton}" Click="unload_for_all"/>
                    <Button Content="Cancel" Width="90" Background="#D32F2F" Click="cancel_process"/>
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Column="2" Background="White" BorderBrush="#D0D7DE" BorderThickness="1,0,0,0">
            <StackPanel Margin="16">
                <TextBlock Text="Import Queue" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

                <TextBlock Text="Global Configuration" FontSize="11" FontWeight="Bold" Foreground="#78909C" Margin="0,0,0,10"/>

                <TextBlock Text="Reference Type"/>
                <ComboBox x:Name="cmbReferenceType" Height="32" Margin="0,4,0,12" SelectedIndex="0">
                    <ComboBoxItem Content="Overlay"/>
                    <ComboBoxItem Content="Attachment"/>
                </ComboBox>

                <TextBlock Text="Positioning"/>
                <ComboBox x:Name="cmbPositioning" Height="32" Margin="0,4,0,12" SelectedIndex="0">
                    <ComboBoxItem Content="Origin to Origin"/>
                    <ComboBoxItem Content="Center to Center"/>
                </ComboBox>

                <TextBlock Text="Selected Link" FontWeight="Bold" Margin="0,18,0,4"/>
                <TextBox x:Name="txtSelectedName" IsReadOnly="True"/>

                <TextBlock Text="Selected Size" FontWeight="Bold" Margin="0,12,0,4"/>
                <TextBox x:Name="txtSelectedSize" IsReadOnly="True"/>

                <TextBlock Text="Full Path" FontWeight="Bold" Margin="0,12,0,4"/>
                <TextBox x:Name="txtSelectedPath"
                         Height="110"
                         TextWrapping="Wrap"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"/>

                <Button Content="Copy Path" Margin="0,8,0,12" Click="copy_selected_path"/>

                <TextBlock Text="IFC Cache"/>
                <TextBlock Text="First load converts IFC. Later loads reuse cache unless rebuild is checked."
                           TextWrapping="Wrap"
                           Foreground="#607D8B"
                           Margin="0,4,0,18"/>

                <Button Content="Apply Settings" Click="apply_settings"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>